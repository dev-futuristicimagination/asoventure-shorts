{
  "framework": "nextjs",
  "crons": [
    // ── TIER 1: Cheese 1本/日（直接収益・収益最大化）
    // UTC 11:00 = JST 20:00
    { "path": "/api/cheese?phase=a", "schedule": "0 11 * * *" },
    { "path": "/api/cheese?phase=b", "schedule": "20 11 * * *" },

    // ── TIER 1: Japan 1本/日（グローバル高CPM・英語コンテンツ）
    // UTC 10:00 = JST 19:00
    { "path": "/api/japan?phase=a",  "schedule": "0 10 * * *" },
    { "path": "/api/japan?phase=b",  "schedule": "20 10 * * *" },

    // ── TIER 2: Job 1本/日（Cheese橋渡し）
    // UTC 11:30 = JST 20:30
    { "path": "/api/job?phase=a",    "schedule": "30 11 * * *" },
    { "path": "/api/job?phase=b",    "schedule": "50 11 * * *" },

    // ── TIER 3: Tips系 週3本（チャンネル登録・認知用・最小コスト）
    // Health: 月水金
    { "path": "/api/health?phase=a", "schedule": "0 12 * * 1,3,5" },
    { "path": "/api/health?phase=b", "schedule": "20 12 * * 1,3,5" },
    // Finance: 火木土
    { "path": "/api/finance?phase=a","schedule": "0 12 * * 2,4,6" },
    { "path": "/api/finance?phase=b","schedule": "20 12 * * 2,4,6" },
    // Education: 月木
    { "path": "/api/education?phase=a","schedule": "30 12 * * 1,4" },
    { "path": "/api/education?phase=b","schedule": "50 12 * * 1,4" },
    // Life: 火金
    { "path": "/api/life?phase=a",   "schedule": "30 12 * * 2,5" },
    { "path": "/api/life?phase=b",   "schedule": "50 12 * * 2,5" },
    // Music1963: 水土
    { "path": "/api/music1963?phase=a","schedule": "0 13 * * 3,6" },
    { "path": "/api/music1963?phase=b","schedule": "20 13 * * 3,6" },

    // ── Canvas動画（Veo3不要・コスト$0）: オウンドメディア系の記事流入導線 ──
    // 毎朝9:00 JST (00:00 UTC) - Veo3とは時間帯を完全に分離
    // 1本あたり約30秒で生成完了（Veo3の20分待機と比較して高速）
    { "path": "/api/health-canvas?phase=canvas",    "schedule": "0 0 * * *" },
    { "path": "/api/finance-canvas?phase=canvas",   "schedule": "5 0 * * *" },
    { "path": "/api/education-canvas?phase=canvas", "schedule": "10 0 * * *" },
    { "path": "/api/life-canvas?phase=canvas",      "schedule": "15 0 * * *" },
    { "path": "/api/japan-canvas?phase=canvas",     "schedule": "20 0 * * *" }
  ]
}
