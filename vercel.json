{
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "includeFiles": "node_modules/ffmpeg-static/**",
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/cheese?phase=a",             "schedule": "0 22 * * *"   },
    { "path": "/api/cheese?phase=b",             "schedule": "20 22 * * *"  },
    { "path": "/api/job?phase=a",                "schedule": "30 22 * * *"  },
    { "path": "/api/job?phase=b",                "schedule": "50 22 * * *"  },
    { "path": "/api/finance?phase=a",            "schedule": "0 3 * * *"    },
    { "path": "/api/finance?phase=b",            "schedule": "20 3 * * *"   },
    { "path": "/api/japan?phase=a",              "schedule": "30 3 * * *"   },
    { "path": "/api/japan?phase=b",              "schedule": "50 3 * * *"   },
    { "path": "/api/health?phase=a",             "schedule": "0 13 * * 1,3,5"  },
    { "path": "/api/health?phase=b",             "schedule": "20 13 * * 1,3,5" },
    { "path": "/api/education?phase=a",          "schedule": "30 13 * * 1,4"   },
    { "path": "/api/education?phase=b",          "schedule": "50 13 * * 1,4"   },
    { "path": "/api/life?phase=a",               "schedule": "30 13 * * 2,5"   },
    { "path": "/api/life?phase=b",               "schedule": "50 13 * * 2,5"   },
    { "path": "/api/music1963?phase=a",          "schedule": "0 14 * * 3,6"    },
    { "path": "/api/music1963?phase=b",          "schedule": "20 14 * * 3,6"   },
    { "path": "/api/cheese-canvas?phase=canvas", "schedule": "0 0 * * *"    },
    { "path": "/api/finance-canvas?phase=canvas","schedule": "5 0 * * *"    },
    { "path": "/api/finance-canvas?phase=canvas","schedule": "0 3 * * *"    },
    { "path": "/api/health-canvas?phase=canvas", "schedule": "10 0 * * *"   },
    { "path": "/api/health-canvas?phase=canvas", "schedule": "10 3 * * *"   },
    { "path": "/api/education-canvas?phase=canvas","schedule": "15 0 * * *" },
    { "path": "/api/life-canvas?phase=canvas",   "schedule": "20 0 * * *"   },
    { "path": "/api/japan-canvas?phase=canvas",  "schedule": "25 0 * * *"   },
    { "path": "/api/job-canvas?phase=canvas",    "schedule": "30 0 * * *"   },
    { "path": "/api/job-canvas?phase=canvas",    "schedule": "0 22 * * *"   },
    { "path": "/api/weekly-landscape",           "schedule": "0 0 * * 1"    },
    { "path": "/api/youtube-analytics",          "schedule": "0 13 * * *"   },
    { "path": "/api/trends-shorts",              "schedule": "0 21 * * 1-5" },
    { "path": "/api/article-pipeline?category=health",    "schedule": "0 1 * * *"  },
    { "path": "/api/article-pipeline?category=finance",   "schedule": "5 1 * * *"  },
    { "path": "/api/article-pipeline?category=education", "schedule": "10 1 * * *" },
    { "path": "/api/article-pipeline?category=life",      "schedule": "15 1 * * *" },
    { "path": "/api/article-pipeline?category=job",       "schedule": "20 1 * * *" },
    { "path": "/api/article-pipeline?category=music1963", "schedule": "25 1 * * *" }
  ]
}